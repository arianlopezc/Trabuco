# Database Configuration for {{.ProjectNamePascal}}
# These defaults are for local development. Override in production via environment variables.
# SECURITY: Always use SSL in production and set strong passwords.

spring:
  datasource:
{{- if eq .Database "postgresql"}}
    # sslmode defaults to `require` since 1.12 — refuses plaintext fallback.
    url: ${DB_URL:jdbc:postgresql://${DB_HOST:localhost}:${DB_PORT:5433}/${DB_NAME:{{.ProjectName}}}?sslmode=${DB_SSL_MODE:require}}
    username: ${DB_USERNAME:postgres}
    password: ${DB_PASSWORD:postgres}
    driver-class-name: org.postgresql.Driver
{{- else if eq .Database "mysql"}}
    url: ${DB_URL:jdbc:mysql://${DB_HOST:localhost}:${DB_PORT:3307}/${DB_NAME:{{.ProjectNameSnake}}}?useSSL=${DB_USE_SSL:true}&requireSSL=${DB_REQUIRE_SSL:false}&verifyServerCertificate=${DB_VERIFY_CERT:false}}
    username: ${DB_USERNAME:root}
    password: ${DB_PASSWORD:root}
    driver-class-name: com.mysql.cj.jdbc.Driver
{{- else}}
    url: ${DB_URL:jdbc:h2:mem:{{.ProjectName}};DB_CLOSE_DELAY=-1}
    username: ${DB_USERNAME:sa}
    password: ${DB_PASSWORD:}
    driver-class-name: org.h2.Driver
{{- end}}

    # HikariCP Connection Pool Settings
    hikari:
      pool-name: ${DB_POOL_NAME:{{.ProjectNamePascal}}Pool}
      maximum-pool-size: ${DB_POOL_SIZE:10}
      minimum-idle: ${DB_POOL_MIN_IDLE:2}
      connection-timeout: ${DB_CONNECTION_TIMEOUT:20000}
      idle-timeout: ${DB_IDLE_TIMEOUT:300000}
      max-lifetime: ${DB_MAX_LIFETIME:1200000}
      # 30s default surfaces connection leaks instead of
      # silently exhausting the pool. Override per workload.
      leak-detection-threshold: ${DB_LEAK_DETECTION:30000}

  # Flyway Migration Settings
  # FLYWAY_USERNAME / FLYWAY_PASSWORD opt operators into
  # separate-user migrations (Flyway runs as a privileged DBA role,
  # runtime app uses a low-privilege role). Default inherits runtime
  # credentials.
  flyway:
    enabled: ${FLYWAY_ENABLED:true}
    user: ${FLYWAY_USERNAME:${DB_USERNAME:postgres}}
    password: ${FLYWAY_PASSWORD:${DB_PASSWORD:postgres}}
    locations: classpath:db/migration
    baseline-on-migrate: ${FLYWAY_BASELINE_ON_MIGRATE:false}
    validate-on-migrate: ${FLYWAY_VALIDATE:true}
    # clean-disabled defaults to true.
    clean-disabled: ${FLYWAY_CLEAN_DISABLED:true}
