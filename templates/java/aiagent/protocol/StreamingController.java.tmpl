package {{.GroupID}}.aiagent.protocol;

import {{.GroupID}}.aiagent.security.CallerContext;
import {{.GroupID}}.aiagent.security.RateLimiter;
import {{.GroupID}}.aiagent.security.RequireScope;
import {{.GroupID}}.aiagent.task.TaskManager;
import com.fasterxml.jackson.databind.ObjectMapper;
import org.springframework.http.HttpStatus;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.RestController;
import org.springframework.web.server.ResponseStatusException;
import org.springframework.web.servlet.mvc.method.annotation.SseEmitter;

import java.util.Map;

@RestController
public class StreamingController {

    /**
     * per-caller cap on concurrent SSE streams. Each
     * emitter pins a Tomcat HTTP thread for up to 60 seconds; one
     * partner opening connections in a loop can exhaust the entire
     * thread pool and deny service to every other caller. The cap
     * is keyed by {@link CallerIdentity#keyHash} so partner-A
     * holding 32 streams doesn't reduce partner-B's quota.
     *
     * <p>32 is conservative for a typical partner load; tune via
     * {@code agent.streaming.max-per-caller} when your traffic
     * profile demands more. Anonymous callers are excluded by the
     * {@code @RequireScope("partner")} gate before this counter
     * even fires.
     */
    private static final int MAX_STREAMS_PER_CALLER = 32;

    private final TaskManager taskManager;
    private final RateLimiter rateLimiter;
    private final ObjectMapper objectMapper = new ObjectMapper();
    private final java.util.concurrent.ConcurrentHashMap<String, java.util.concurrent.atomic.AtomicInteger> activeStreamsByCaller =
        new java.util.concurrent.ConcurrentHashMap<>();

    public StreamingController(TaskManager taskManager, RateLimiter rateLimiter) {
        this.taskManager = taskManager;
        this.rateLimiter = rateLimiter;
    }

    @GetMapping("/tasks/{taskId}/stream")
    @RequireScope("partner")
    public SseEmitter streamTask(@PathVariable String taskId) {
        var caller = CallerContext.get();
        rateLimiter.checkRateLimit(caller);

        // Enforce concurrent-stream cap before allocating
        // an emitter (which would otherwise grab a Tomcat thread).
        java.util.concurrent.atomic.AtomicInteger active = activeStreamsByCaller
            .computeIfAbsent(caller.keyHash(), k -> new java.util.concurrent.atomic.AtomicInteger(0));
        if (active.incrementAndGet() > MAX_STREAMS_PER_CALLER) {
            active.decrementAndGet();
            throw new ResponseStatusException(HttpStatus.TOO_MANY_REQUESTS,
                "SSE stream cap exceeded (" + MAX_STREAMS_PER_CALLER + " concurrent per caller)");
        }

        // Ownership check: getTaskForOwner returns
        // Optional.empty() if the task doesn't exist OR if the caller
        // didn't submit it. Both cases throw 404 — same shape, no
        // information about whether the task UUID exists.
        var task = taskManager.getTaskForOwner(taskId, caller.keyHash())
            .orElseThrow(() -> new ResponseStatusException(HttpStatus.NOT_FOUND, "Task not found: " + taskId));

        SseEmitter emitter = new SseEmitter(60_000L); // 60 second timeout

        // Capture the subscriber lambda so the same instance can be
        // unsubscribed on emitter teardown. Without an unsubscribe call,
        // each completed/timed-out emitter leaves its closure in
        // TaskManager#subscribers — eventually hitting SUBSCRIBERS_MAX_PER_TASK
        // (32) and silently dropping every new subscriber for that task.
        java.util.function.Consumer<{{.GroupID}}.aiagent.task.TaskEvent> listener = event -> {
            try {
                String data = objectMapper.writeValueAsString(Map.of(
                    "task_id", event.taskId(),
                    "status", event.status(),
                    "result", event.result() != null ? event.result() : "",
                    "error", event.error() != null ? event.error() : "",
                    "timestamp", event.timestamp().toString()
                ));
                emitter.send(SseEmitter.event()
                    .name(event.status())
                    .data(data));

                if ("completed".equals(event.status()) || "failed".equals(event.status())) {
                    emitter.complete();
                }
            } catch (Exception e) {
                emitter.completeWithError(e);
            }
        };

        // releaseSlot decrements the per-caller cap AND removes the
        // subscriber. Both must run on every terminal SSE state —
        // completion, timeout, error. Without unsubscribe, finished
        // streams leak listeners forever.
        Runnable releaseSlot = () -> {
            taskManager.unsubscribe(taskId, listener);
            int remaining = active.decrementAndGet();
            if (remaining <= 0) {
                activeStreamsByCaller.remove(caller.keyHash());
            }
        };
        emitter.onCompletion(releaseSlot);
        emitter.onTimeout(() -> {
            releaseSlot.run();
            emitter.complete();
        });
        emitter.onError(t -> releaseSlot.run());

        taskManager.subscribe(taskId, listener);

        // If task already completed, send current state and close
        if ("completed".equals(task.getStatus()) || "failed".equals(task.getStatus())) {
            try {
                String data = objectMapper.writeValueAsString(Map.of(
                    "task_id", task.getTaskId(),
                    "status", task.getStatus(),
                    "result", task.getResult() != null ? task.getResult() : "",
                    "error", task.getError() != null ? task.getError() : ""
                ));
                emitter.send(SseEmitter.event().name(task.getStatus()).data(data));
                emitter.complete();
            } catch (Exception e) {
                emitter.completeWithError(e);
            }
        }

        return emitter;
    }
}
