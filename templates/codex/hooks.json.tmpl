{
  "hooks": [
    {
      "event": "PostToolUse",
      "matcher": "Bash",
      "handlers": [
        {
          "type": "command",
          "command": "mvn spotless:apply -q 2>/dev/null || true",
          "timeout": 30
        }
      ]
    }{{- if .ReviewEmitsStopHook}},
    {
      "event": "Stop",
      "handlers": [
        {
          "type": "command",
          "command": ".codex/hooks/require-review.sh",
          "timeout": 60
        }
      ]
    }
    {{- end}}
  ]
}
